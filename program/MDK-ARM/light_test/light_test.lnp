--cpu Cortex-M0
"light_test\main.o"
"light_test\gpio.o"
"light_test\stm32f0xx_it.o"
"light_test\stm32f0xx_hal_msp.o"
"light_test\stm32f0xx_hal_tim.o"
"light_test\stm32f0xx_hal_tim_ex.o"
"light_test\stm32f0xx_hal_rcc.o"
"light_test\stm32f0xx_hal_rcc_ex.o"
"light_test\stm32f0xx_hal.o"
"light_test\stm32f0xx_hal_i2c.o"
"light_test\stm32f0xx_hal_i2c_ex.o"
"light_test\stm32f0xx_hal_gpio.o"
"light_test\stm32f0xx_hal_dma.o"
"light_test\stm32f0xx_hal_cortex.o"
"light_test\stm32f0xx_hal_pwr.o"
"light_test\stm32f0xx_hal_pwr_ex.o"
"light_test\stm32f0xx_hal_flash.o"
"light_test\stm32f0xx_hal_flash_ex.o"
"light_test\stm32f0xx_hal_exti.o"
"light_test\system_stm32f0xx.o"
"light_test\startup_stm32f030x6.o"
"light_test\bsp_tim.o"
--strict --scatter "light_test\light_test.sct"
--summary_stderr --info summarysizes --map --load_addr_map_info --xref --callgraph --symbols
--info sizes --info totals --info unused --info veneers
--list "./light_test/\light_test.map" -o light_test\light_test.axf